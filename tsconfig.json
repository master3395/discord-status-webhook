{
	"compilerOptions": {
		"strict": true,
		"moduleResolution": "nodenext",
		"module": "nodenext",
		"target": "es2022",
		"declaration": true,
		"sourceMap": true,
		"removeComments": false,
		"alwaysStrict": true,
		"pretty": true,
		"outDir": "dist",
		"incremental": true,
		"noEmitHelpers": true,
		"importHelpers": true,
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"exclude": ["**/*.test.ts", "dist"]
}
